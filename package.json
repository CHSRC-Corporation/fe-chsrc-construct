{
  "name": "fe-chsrc-construct",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test src/tests/*.test.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "cy:open": "env -u ELECTRON_RUN_AS_NODE cypress open",
